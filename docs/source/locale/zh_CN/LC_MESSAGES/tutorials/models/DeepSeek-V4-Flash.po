msgstr "预期结果："

msgid "|Parameter|Type|Required|Default|Description|"
msgstr "|参数|类型|必填|默认值|描述|"

msgid "| dataset | version | metric | mode | vllm-api-general-chat | note |"
msgstr "| 数据集 | 版本 | 指标 | 模式 | vllm-api-general-chat | 备注 |"

msgid ""
"|Scenario|Deployment Mode|*Total NPUs|Weight Version|Key Considerations|"
msgstr "|场景|部署模式|*NPU总数|权重版本|关键考量|"

